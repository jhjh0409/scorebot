# ---- LLM ----
# Switching LLMs is a pure env change: set DEFAULT_MODEL and the provider is
# inferred from the name (gemini-* / claude-* / gpt-* / local names -> ollama).
# LLM_PROVIDER (ollama | gemini | anthropic | openai) only decides for model
# ids the prefix rules don't recognize (fine-tunes, proxies).
DEFAULT_MODEL=gemini-2.5-flash-lite
# LLM_PROVIDER=gemini

# API key for whichever provider the model resolves to
GEMINI_API_KEY=your_gemini_api_key_here
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Examples:
#   DEFAULT_MODEL=gemini-2.5-flash-lite  + GEMINI_API_KEY     (default)
#   DEFAULT_MODEL=claude-sonnet-5        + ANTHROPIC_API_KEY
#   DEFAULT_MODEL=gpt-5.1-mini           + OPENAI_API_KEY
#   DEFAULT_MODEL=gemma3:4b              (local Ollama, no key)

# ---- Postgres (presets/config only — no candidate data) ----
DATABASE_URL=postgresql+psycopg://scorebot:scorebot@localhost:5434/scorebot

# ---- Screening jobs (in-memory queue) ----
SCREENING_WORKERS=2
LLM_MAX_CONCURRENCY=2

# ---- Rate limits (in-process; see README) ----
# API_RATE_LIMIT_PER_MINUTE=120
# SCREENINGS_PER_HOUR_PER_IP=20
# SCREENINGS_PER_HOUR_GLOBAL=60

# ---- Optional ----
# GITHUB_TOKEN=            # raises GitHub API limits for enrichment
# DEVELOPMENT_MODE=true    # local cache/ for parse+GitHub results
